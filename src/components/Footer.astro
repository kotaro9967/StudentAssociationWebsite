---
const footerLinks = {
  about: [
    { label: "学友会について", href: "#" },
    { label: "組織図", href: "#" },
    { label: "役員紹介", href: "#" },
    { label: "活動報告", href: "#" },
  ],
  support: [
    { label: "よくある質問", href: "#" },
    { label: "お問い合わせ", href: "#" },
    { label: "施設予約ガイド", href: "#" },
    { label: "物品貸出ガイド", href: "#" },
  ],
  legal: [
    { label: "学友会規約", href: "#" },
    { label: "プライバシーポリシー", href: "#" },
    { label: "利用規約", href: "#" },
    { label: "サイトマップ", href: "#" },
  ],
};
---

<footer class="bg-black text-white pt-16 sm:pt-20 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 sm:gap-12 mb-12 sm:mb-16">
      
      <div class="lg:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <img
            src="/StudentAssociationWebsite/学友会アイコン.png"
            alt="学友会ロゴ"
            class="w-10 h-10 object-contain brightness-0 invert"
          />
          <div>
            <div class="text-base font-serif">東京理科大学</div>
            <div class="text-sm text-white/60 font-serif">学友会</div>
          </div>
        </div>
        <p class="text-sm text-white/60 leading-relaxed mb-6">
          学生の、学生による、<br />学生のための組織
        </p>
        <div class="space-y-3">
          <div class="flex items-center gap-3 text-sm text-white/60">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            <span>gakuyukai@tus.ac.jp</span>
          </div>
          <div class="flex items-center gap-3 text-sm text-white/60">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            <span>03-1234-5678</span>
          </div>
          <div class="flex items-start gap-3 text-sm text-white/60">
            <svg class="w-4 h-4 mt-1 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            <span>東京都新宿区神楽坂1-3</span>
          </div>
        </div>
      </div>

      <div>
        <h3 class="mb-4 text-sm uppercase tracking-wider text-white/40">About</h3>
        <ul class="space-y-3">
          {footerLinks.about.map((link) => (
            <li><a href={link.href} class="text-sm text-white/80 hover:text-white transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-4 text-sm uppercase tracking-wider text-white/40">Support</h3>
        <ul class="space-y-3">
          {footerLinks.support.map((link) => (
            <li><a href={link.href} class="text-sm text-white/80 hover:text-white transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-4 text-sm uppercase tracking-wider text-white/40">Legal</h3>
        <ul class="space-y-3">
          {footerLinks.legal.map((link) => (
            <li><a href={link.href} class="text-sm text-white/80 hover:text-white transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-white/10">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
        <p class="text-sm text-white/40">
          © 2026 Tokyo University of Science Student Association. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>