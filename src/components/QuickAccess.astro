---
// Bento Grid 用のカスタムスタイルを配列に持たせます
const services = [
  {
    title: "施設予約", description: "体育館や教室などの施設を簡単に予約できます",
    icon: '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line>',
    bentoClass: "md:col-span-2 md:row-span-2 bg-[var(--navy)] text-white", // 一番目立つ特大ブロック
    iconBg: "bg-white/20", iconColor: "text-white"
  },
  {
    title: "物品貸出", description: "イベント用品の貸出",
    icon: '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line>',
    bentoClass: "md:col-span-1 md:row-span-1 bg-white",
    iconBg: "bg-[var(--navy-light)]", iconColor: "text-white"
  },
  {
    title: "キャンパスマップ", description: "各キャンパスの詳細情報",
    icon: '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle>',
    bentoClass: "md:col-span-1 md:row-span-1 bg-white",
    iconBg: "bg-[var(--navy)]", iconColor: "text-white"
  },
  {
    title: "各種申請", description: "活動に必要な手続き",
    icon: '<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line>',
    bentoClass: "md:col-span-1 md:row-span-1 bg-white",
    iconBg: "bg-[var(--navy-light)]", iconColor: "text-white"
  },
  {
    title: "サークル登録", description: "新規設立はこちらから",
    icon: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
    bentoClass: "md:col-span-2 md:row-span-1 bg-gray-100", // 横長ブロック
    iconBg: "bg-[var(--navy)]", iconColor: "text-white"
  },
];
---

<section id="クイックアクセス" class="py-20 sm:py-32 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-white to-gray-50 overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div class="mb-16 text-center qa-header opacity-0">
      <div class="inline-block mb-4 px-4 py-2 rounded-full bg-black/5 text-sm text-black/60">
        Quick Access
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl mb-4 tracking-tight font-serif">
        クイックアクセス
      </h2>
      <p class="text-base sm:text-lg text-black/60 max-w-2xl mx-auto">
        よく使うサービスに素早くアクセス
      </p>
    </div>

    {/* Bento Grid レイアウト */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 auto-rows-[minmax(180px,auto)]">
      {services.map((service) => (
        <button class={`bento-card opacity-0 group p-6 sm:p-8 rounded-3xl border border-black/5 hover:border-black/10 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 text-left flex flex-col justify-between ${service.bentoClass}`}>
          <div>
            <div class={`w-12 h-12 sm:w-14 sm:h-14 rounded-2xl flex items-center justify-center mb-6 transition-transform group-hover:scale-110 ${service.iconBg} ${service.iconColor}`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={service.icon} />
            </div>
            <h3 class={`text-xl sm:text-2xl font-bold mb-2 ${service.bentoClass.includes('text-white') ? 'text-white' : 'text-gray-900'}`}>{service.title}</h3>
          </div>
          <p class={`text-sm sm:text-base leading-relaxed mt-2 ${service.bentoClass.includes('text-white') ? 'text-white/80' : 'text-black/60'}`}>
            {service.description}
          </p>
        </button>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // ヘッダーのフェードイン
  gsap.to(".qa-header", {
    scrollTrigger: { trigger: ".qa-header", start: "top 80%" },
    y: -30, opacity: 1, duration: 1, ease: "power3.out"
  });

  // Bento Gridの時間差（stagger）アニメーション
  gsap.to(".bento-card", {
    scrollTrigger: { trigger: ".bento-card", start: "top 85%" },
    y: 0, opacity: 1, duration: 0.8, stagger: 0.15, ease: "back.out(1.2)"
  });
</script>