---
const images = [
  '東京理科大学1.jpg',
  '東京理科大学2.jpg',
  '東京理科大学3.jpg',
  '東京理科大学4.jpg',
  '東京理科大学5.jpg'
];
---

<style>
  .bg-slide {
    position: absolute; inset: 0; width: 100%; height: 100%;
    background-size: cover; background-position: center; opacity: 0;
    animation: fadeZoom 40s infinite;
  }
  @keyframes fadeZoom {
    0% { opacity: 0; transform: scale(1.08); }
    5% { opacity: 1; }
    20% { opacity: 1; }
    25% { opacity: 0; transform: scale(1); }
    100% { opacity: 0; transform: scale(1); }
  }
</style>

<section class="min-h-screen flex flex-col justify-end pb-10 sm:pb-16 px-4 sm:px-8 lg:px-12 relative overflow-hidden bg-black">
  <div id="hero-bg-container" class="absolute inset-0 w-full h-full will-change-[filter]">
    {images.map((img, index) => (
      <div class="bg-slide" style={`background-image: url('${img}'); animation-delay: ${index * 8}s;`}></div>
    ))}
  </div>
  <div id="hero-overlay" class="absolute inset-0 bg-black/40 will-change-opacity"></div>

  <div class="w-full relative z-10">
    <div id="hero-content" style="will-change: opacity, transform;">
      <h1 class="hero-title text-4xl sm:text-5xl md:text-7xl font-serif text-white tracking-widest drop-shadow-[0_15px_30px_rgba(0,0,0,0.9)] opacity-0">
        東京理科大学
        <br class="hidden sm:block" />
        学友会
      </h1>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";

  // ロード時のタイトルアニメーション
  gsap.to(".hero-title", {
    y: -20, opacity: 1, duration: 1.5, ease: "power3.out", delay: 0.5
  });

  // スクロールぼかし（Vanilla JSのままが最速です）
  const heroContent = document.getElementById('hero-content');
  const heroBgContainer = document.getElementById('hero-bg-container');
  const heroOverlay = document.getElementById('hero-overlay');

  if (heroContent && heroBgContainer && heroOverlay) {
    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      heroContent.style.opacity = Math.max(1 - scrollY / 400, 0).toString();
      heroBgContainer.style.filter = `blur(${Math.min(scrollY * 0.05, 20)}px)`;
      heroOverlay.style.opacity = Math.min(0.4 + scrollY / 1000, 0.85).toString();
    });
  }
</script>